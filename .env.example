# Copy to .env and fill in. All VITE_* vars are exposed to the browser; never put secrets there.

# Lovable Cloud / Supabase (publishable keys — safe in client)
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Server-side mirror (used during SSR)
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
SUPABASE_PROJECT_ID="your-project-id"

# Lovable AI Gateway (server-only — required for the Cipher AI mentor)
# Get this from Lovable workspace settings, or swap for your own provider.
LOVABLE_API_KEY="your-lovable-api-key"
